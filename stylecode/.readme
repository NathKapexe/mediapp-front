/* ================================================================
   app.css — MediChain App del Paciente (PWA Móvil)
   Diseño: "Clinical Warmth" — oscuro en encabezados, cálido en
   contenido, tipografía Syne (display) + DM Sans (body).

   ÍNDICE:
   1.  Variables globales
   2.  Reset y base
   3.  Splash screen
   4.  Login screen
   5.  App shell (estructura)
   6.  Status bar
   7.  App header
   8.  Bottom navigation
   9.  Content area y screens
   10. Componentes: cards, badges, botones
   11. Home screen
   12. Perfil
   13. Documentos
   14. Doctores
   15. Citas (tabs + calendar)
   16. Medicamentos
   17. Análisis / Estudios
   18. Vacunas
   19. Notificaciones
   20. Token de acceso
   21. Bottom sheets
   22. Formularios
   23. Animaciones
   24. Responsive / safe-areas
================================================================ */


/* ================================================================
   1. VARIABLES GLOBALES
================================================================ */
:root {
  --bg:          #f2f5f8;
  --card:        #ffffff;
  --dark:        #0d1b2a;
  --dark2:       #172536;
  --accent:      #0ea5a0;
  --accent-lt:   #e0f5f4;
  --accent-dk:   #097b76;
  --text:        #1a2332;
  --text-muted:  #6b7a8d;
  --border:      #dde3ec;
  --danger:      #e05252;
  --warn:        #e09a2b;
  --ok:          #2bbf6e;
  --info:        #5b9bd5;

  /* Tipografía */
  --font-display: 'Syne', sans-serif;
  --font-body:    'DM Sans', sans-serif;

  /* Layout */
  --header-h:    56px;
  --status-h:    28px;
  --nav-h:       64px;
  --radius:      14px;
  --radius-sm:   9px;
  --shadow:      0 2px 16px rgba(13,27,42,.1);
  --shadow-lg:   0 8px 32px rgba(13,27,42,.18);
  --transition:  .22s cubic-bezier(.4,0,.2,1);
}


/* ================================================================
   2. RESET Y BASE
================================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  /* Altura total de la pantalla en móvil incluyendo safe areas */
  height: -webkit-fill-available;
}

body {
  font-family: var(--font-body);
  background: var(--dark);
  color: var(--text);
  min-height: 100vh;
  min-height: -webkit-fill-available;
  overflow: hidden;            /* Sin scroll en el body — el scroll va dentro de .app-content */
  -webkit-tap-highlight-color: transparent;  /* Quita el flash azul en tap en Android */
  user-select: none;           /* Comportamiento más nativo */
}

.hidden { display: none !important; }
.mt-1   { margin-top: .6rem; }
.mt-2   { margin-top: 1.2rem; }


/* ================================================================
   3. SPLASH SCREEN
================================================================ */
#splash {
  position: fixed; inset: 0; z-index: 9999;
  background: linear-gradient(160deg, var(--dark) 0%, #134e5e 70%, var(--accent) 100%);
  display: flex; align-items: center; justify-content: center;
  animation: splashOut .5s ease .8s forwards;   /* Auto-desaparece en .8s */
}

@keyframes splashOut {
  to { opacity: 0; pointer-events: none; }
}

.splash-inner { text-align: center; }

.splash-logo {
  font-size: 3.5rem;
  animation: splashPop .5s cubic-bezier(.34,1.56,.64,1) both;
}

@keyframes splashPop {
  from { transform: scale(0.5); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}

.splash-title {
  font-family: var(--font-display);
  font-size: 2rem; font-weight: 800;
  color: #fff; margin: .5rem 0 .2rem;
  letter-spacing: -.02em;
}

.splash-sub { color: rgba(255,255,255,.6); font-size: .9rem; }


/* ================================================================
   4. LOGIN SCREEN
================================================================ */
#screen-login {
  position: fixed; inset: 0; z-index: 9000;
  background: var(--dark);
  display: flex; flex-direction: column;
  overflow-y: auto;
}

.login-bg-deco {
  /* Decoración de fondo del login */
  position: absolute; top: -80px; right: -80px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(14,165,160,.35) 0%, transparent 70%);
  pointer-events: none;
}

.login-wrap {
  flex: 1; display: flex; flex-direction: column;
  justify-content: center; padding: 2rem 1.5rem;
  min-height: 100vh; position: relative;
}

.login-logo-block {
  text-align: center; margin-bottom: 2.5rem;
}

.login-icon {
  font-size: 2.8rem; margin-bottom: .5rem;
  display: inline-block;
  animation: splashPop .5s cubic-bezier(.34,1.56,.64,1) .3s both;
}

.login-title {
  font-family: var(--font-display);
  font-size: 2.2rem; font-weight: 800;
  color: #fff; letter-spacing: -.03em;
}

.login-tagline {
  color: var(--accent); font-size: .85rem;
  font-weight: 600; letter-spacing: .12em;
  text-transform: uppercase; margin-top: .2rem;
}

.login-card {
  background: #fff; border-radius: 20px;
  padding: 1.8rem 1.5rem;
  box-shadow: 0 20px 60px rgba(0,0,0,.4);
}

.login-card h2 {
  font-family: var(--font-display);
  font-size: 1.4rem; font-weight: 700; margin-bottom: .25rem;
}

.login-hint { color: var(--text-muted); font-size: .85rem; margin-bottom: 1.4rem; }

.login-demo-note {
  text-align: center; margin-top: .9rem;
  font-size: .78rem; color: var(--text-muted);
}


/* ================================================================
   5. APP SHELL
================================================================ */
#app-shell {
  position: fixed; inset: 0;
  display: flex; flex-direction: column;
  background: var(--bg);
  /* Safe area support para notch de iPhone */
  padding-bottom: env(safe-area-inset-bottom, 0);
}


/* ================================================================
   6. STATUS BAR (simulada)
================================================================ */
.status-bar {
  height: var(--status-h);
  background: var(--dark);
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 0 1.2rem;
  font-size: .72rem; font-weight: 600;
  color: rgba(255,255,255,.85);
  flex-shrink: 0;
}

.status-icons { letter-spacing: .05em; }


/* ================================================================
   7. APP HEADER
================================================================ */
.app-header {
  height: var(--header-h);
  background: var(--dark);
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 0 1rem 0 .8rem;
  flex-shrink: 0;
}

.header-back {
  width: 36px; height: 36px;
  border: none; background: rgba(255,255,255,.1);
  color: #fff; font-size: 1.5rem; font-weight: 300;
  border-radius: 50%; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  padding-bottom: 2px;
  transition: background var(--transition);
}

.header-back:hover { background: rgba(255,255,255,.2); }

.header-title {
  font-family: var(--font-display);
  font-size: 1.05rem; font-weight: 700;
  color: #fff; letter-spacing: -.01em;
  flex: 1; text-align: center;
}

.header-action {
  width: 36px; height: 36px;
  border: none; background: none;
  color: rgba(255,255,255,.8);
  font-size: 1.1rem; cursor: pointer;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: background var(--transition);
}

.header-action:hover { background: rgba(255,255,255,.1); }


/* ================================================================
   8. BOTTOM NAVIGATION BAR
================================================================ */
.bottom-nav {
  height: var(--nav-h);
  background: var(--dark);
  display: flex; align-items: center;
  justify-content: space-around;
  flex-shrink: 0;
  border-top: 1px solid rgba(255,255,255,.07);
  padding: 0 .5rem;
}

.bn-item {
  flex: 1; height: 100%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: .2rem; border: none; background: none;
  cursor: pointer; color: rgba(255,255,255,.4);
  transition: color var(--transition);
  font-family: var(--font-body);
}

.bn-item:active { transform: scale(.93); }

.bn-item.active { color: var(--accent); }

.bn-icon  { font-size: 1.3rem; line-height: 1; }
.bn-label { font-size: .65rem; font-weight: 600; letter-spacing: .02em; }

/* Botón FAB central (subir documento) */
.bn-fab {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent-dk));
  color: #fff; font-size: 1.6rem; font-weight: 300;
  border: 3px solid var(--dark);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(14,165,160,.5);
  transition: transform var(--transition), box-shadow var(--transition);
  flex-shrink: 0;
}

.bn-fab:active {
  transform: scale(.9);
  box-shadow: 0 2px 8px rgba(14,165,160,.4);
}


/* ================================================================
   9. CONTENT AREA Y SCREENS
================================================================ */
.app-content {
  flex: 1; overflow: hidden; position: relative;
}

/* Cada screen ocupa todo el espacio y scrollea independientemente */
.app-screen {
  display: none;
  position: absolute; inset: 0;
  overflow-y: auto; overflow-x: hidden;
  padding: 1rem 1rem 1.5rem;
  /* Scroll con inercia (efecto nativo iOS) */
  -webkit-overflow-scrolling: touch;
  animation: screenIn .25s ease;
}

.app-screen.active { display: block; }

@keyframes screenIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Sub-screens (tabs internas) */
.sub-screen { display: none; animation: screenIn .2s ease; }
.sub-screen.active { display: block; }


/* ================================================================
   10. COMPONENTES GENERALES
================================================================ */

/* --- Section header (título de sección + acción derecha) --- */
.section-header {
  display: flex; align-items: center;
  justify-content: space-between;
  margin: 1.2rem 0 .6rem;
  font-size: .82rem; font-weight: 700;
  color: var(--text);
}

.link-btn {
  background: none; border: none;
  color: var(--accent); font-size: .8rem;
  font-weight: 600; cursor: pointer;
  font-family: var(--font-body);
}

/* --- Info card (contenedor de campos) --- */
.info-card {
  background: var(--card); border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 1rem 1.1rem;
  margin-bottom: .9rem;
}

.ic-title {
  font-size: .72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .07em;
  color: var(--text-muted); margin-bottom: .8rem;
}

.ic-row {
  display: flex; justify-content: space-between;
  align-items: center; padding: .5rem 0;
  border-bottom: 1px solid var(--border);
  font-size: .88rem;
}

.ic-row:last-child { border-bottom: none; }
.ic-lbl { color: var(--text-muted); font-size: .82rem; }

/* --- Badges generales --- */
.badge {
  display: inline-flex; align-items: center;
  padding: .18rem .65rem; border-radius: 999px;
  font-size: .7rem; font-weight: 700;
}

/* --- Botones --- */
.btn-full {
  width: 100%; padding: .85rem;
  background: var(--accent); color: #fff;
  border: none; border-radius: var(--radius);
  font-family: var(--font-body); font-size: .95rem;
  font-weight: 600; cursor: pointer;
  transition: background var(--transition), transform var(--transition);
}

.btn-full:active { transform: scale(.98); background: var(--accent-dk); }

.btn-full.outline {
  background: transparent; color: var(--accent);
  border: 1.5px solid var(--accent);
}

.btn-full.outline:active { background: var(--accent-lt); }

.btn-outline-sm {
  padding: .4rem .9rem; border-radius: 8px;
  background: transparent; color: var(--accent);
  border: 1.5px solid var(--accent);
  font-family: var(--font-body); font-size: .8rem;
  font-weight: 600; cursor: pointer;
}

.btn-danger-sm {
  padding: .5rem 1rem; border-radius: 8px;
  background: #fde8e8; color: var(--danger);
  border: 1.5px solid #f5baba;
  font-family: var(--font-body); font-size: .82rem;
  font-weight: 600; cursor: pointer; width: 100%;
}

/* Sub-tabs (dentro de una sección) */
.sub-tabs {
  display: flex; gap: .4rem;
  overflow-x: auto; padding-bottom: .2rem;
  scrollbar-width: none; margin-bottom: .8rem;
}

.sub-tabs::-webkit-scrollbar { display: none; }

.st {
  padding: .45rem 1rem; border-radius: 999px;
  border: 1.5px solid var(--border);
  background: var(--card); color: var(--text-muted);
  font-family: var(--font-body); font-size: .8rem;
  font-weight: 600; cursor: pointer; white-space: nowrap;
  transition: all var(--transition);
}

.st.active {
  background: var(--accent); color: #fff;
  border-color: var(--accent);
  box-shadow: 0 2px 10px rgba(14,165,160,.35);
}

/* Lista group label */
.list-group-label {
  font-size: .72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .07em;
  color: var(--text-muted); margin: .8rem 0 .4rem;
}


/* ================================================================
   11. HOME SCREEN
================================================================ */
.home-greeting {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 1rem;
}

.greeting-sub  { font-size: .8rem; color: var(--text-muted); }
.greeting-name {
  font-family: var(--font-display);
  font-size: 1.3rem; font-weight: 700;
  letter-spacing: -.02em;
}

/* Avatar clickeable del usuario en el home */
.home-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #134e5e);
  color: #fff; display: flex; align-items: center;
  justify-content: center; font-weight: 700;
  font-size: .95rem; cursor: pointer; flex-shrink: 0;
  box-shadow: 0 2px 10px rgba(14,165,160,.4);
}

/* Card de próxima cita */
.next-appt-card {
  background: linear-gradient(135deg, var(--dark2) 0%, #0f3a4d 100%);
  border-radius: var(--radius); padding: 1.1rem;
  margin-bottom: 1.2rem; cursor: pointer; position: relative;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(13,27,42,.25);
}

/* Decoración circular de fondo */
.next-appt-card::after {
  content: '';
  position: absolute; right: -30px; top: -30px;
  width: 120px; height: 120px;
  border-radius: 50%; background: rgba(14,165,160,.15);
  pointer-events: none;
}

.nac-label {
  font-size: .72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .08em;
  color: var(--accent); margin-bottom: .6rem;
}

.nac-info { margin-bottom: .8rem; }
.nac-info strong { display: block; color: #fff; font-size: 1rem; font-weight: 600; }
.nac-info span   { color: rgba(255,255,255,.55); font-size: .82rem; }

.nac-date {
  display: flex; align-items: baseline; gap: .4rem; margin-bottom: .8rem;
}

.nac-day   { font-family: var(--font-display); font-size: 2rem; font-weight: 800; color: #fff; line-height: 1; }
.nac-month { color: rgba(255,255,255,.55); font-size: .85rem; }
.nac-time  { color: var(--accent); font-weight: 700; font-size: .85rem; margin-left: auto; }

/* Badge de token en la card de cita */
.nac-token {
  display: inline-flex; align-items: center; gap: .3rem;
  padding: .25rem .7rem; border-radius: 999px;
  font-size: .75rem; font-weight: 700;
  background: rgba(255,255,255,.1); color: rgba(255,255,255,.5);
}

.nac-token.active {
  background: rgba(14,165,160,.25); color: var(--accent);
  border: 1px solid rgba(14,165,160,.4);
}

/* Medicamentos del día */
.meds-today-list { display: flex; flex-direction: column; gap: .5rem; margin-bottom: .3rem; }

.med-today-chip {
  display: flex; align-items: center; gap: .8rem;
  background: var(--card); border-radius: var(--radius-sm);
  padding: .7rem .9rem; box-shadow: var(--shadow);
}

.med-today-chip.taken { opacity: .55; }

.mtc-icon { font-size: 1.1rem; }
.mtc-info { flex: 1; }
.mtc-info b     { display: block; font-size: .88rem; }
.mtc-info small { color: var(--text-muted); font-size: .75rem; }

/* Grid de accesos rápidos */
.quick-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: .6rem; margin-bottom: 1rem;
}

.qg-item {
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .8rem .4rem;
  display: flex; flex-direction: column;
  align-items: center; gap: .3rem; cursor: pointer;
  transition: transform var(--transition), box-shadow var(--transition);
}

.qg-item:active { transform: scale(.95); }
.qg-item span  { font-size: 1.4rem; }
.qg-item small { font-size: .68rem; font-weight: 600; color: var(--text-muted); }

/* Preview de notificación en home */
.notif-preview {
  display: flex; align-items: flex-start; gap: .8rem;
  background: var(--card); border-radius: var(--radius-sm);
  padding: .9rem; box-shadow: var(--shadow); cursor: pointer;
}

.notif-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0; margin-top: .3rem;
}

.notif-text { flex: 1; }
.notif-text b { font-size: .88rem; display: block; margin-bottom: .2rem; }
.notif-text p { font-size: .78rem; color: var(--text-muted); line-height: 1.4; }
.notif-time   { font-size: .7rem; color: var(--text-muted); white-space: nowrap; margin-top: .15rem; }


/* ================================================================
   12. PERFIL
================================================================ */
.profile-hero {
  text-align: center; padding: 1.2rem 0 1.5rem;
  display: flex; flex-direction: column; align-items: center; gap: .5rem;
}

.profile-avatar-lg {
  width: 76px; height: 76px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #134e5e);
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; font-weight: 700;
  box-shadow: 0 4px 20px rgba(14,165,160,.4);
  margin-bottom: .2rem;
}

.profile-hero h3 {
  font-family: var(--font-display); font-size: 1.2rem; font-weight: 700;
}

.profile-hero p { color: var(--text-muted); font-size: .82rem; }

/* Chip de padecimiento */
.condition-chip {
  display: inline-flex; align-items: center; gap: .4rem;
  background: var(--accent-lt); color: var(--accent-dk);
  border-radius: 8px; padding: .45rem .9rem;
  font-size: .83rem; font-weight: 600; margin: .3rem .3rem 0 0;
}

/* Card colapsable */
.collapsible-card {
  background: var(--card); border-radius: var(--radius);
  box-shadow: var(--shadow); margin-bottom: .9rem; overflow: hidden;
}

.cc-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: .9rem 1.1rem; cursor: pointer; font-size: .88rem; font-weight: 600;
  transition: background var(--transition);
}

.cc-header:active { background: var(--bg); }

.cc-arrow {
  color: var(--text-muted); font-size: .75rem;
  transition: transform var(--transition);
}

.collapsible-card.open .cc-arrow { transform: rotate(180deg); }

.cc-body {
  /* Misma técnica max-height que el web */
  max-height: 0; overflow: hidden;
  transition: max-height .35s ease, padding var(--transition);
  padding: 0 1.1rem;
  border-top: 0 solid var(--border);
}

.collapsible-card.open .cc-body {
  max-height: 400px;
  padding: .8rem 1.1rem 1.1rem;
  border-top-width: 1px;
}

/* Contacto de emergencia */
.emergency-contact {
  display: flex; align-items: center; gap: .9rem;
  padding: .6rem 0; border-bottom: 1px solid var(--border);
}

.emergency-contact:last-of-type { border-bottom: none; }

.ec-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, #6c8ebf, #3b5998);
  color: #fff; display: flex; align-items: center;
  justify-content: center; font-size: .75rem; font-weight: 700;
  flex-shrink: 0;
}

.ec-info { flex: 1; }
.ec-info b     { font-size: .88rem; display: block; }
.ec-info small { color: var(--text-muted); font-size: .75rem; }

.ec-call {
  font-size: 1.2rem; text-decoration: none;
  width: 34px; height: 34px; border-radius: 50%;
  background: var(--accent-lt); display: flex;
  align-items: center; justify-content: center;
}


/* ================================================================
   13. DOCUMENTOS
================================================================ */
.doc-toolbar {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: .8rem; gap: .6rem;
}

.doc-filter-tabs {
  display: flex; gap: .3rem; overflow-x: auto;
  scrollbar-width: none; flex: 1;
}

.doc-filter-tabs::-webkit-scrollbar { display: none; }

.dft {
  padding: .35rem .8rem; border-radius: 999px;
  border: 1.5px solid var(--border);
  background: none; font-family: var(--font-body);
  font-size: .75rem; font-weight: 600;
  color: var(--text-muted); cursor: pointer; white-space: nowrap;
  transition: all var(--transition);
}

.dft.active { background: var(--accent); color: #fff; border-color: var(--accent); }

.btn-upload {
  padding: .4rem .9rem; border-radius: 8px;
  background: var(--accent); color: #fff;
  border: none; font-family: var(--font-body);
  font-size: .8rem; font-weight: 700; cursor: pointer;
  flex-shrink: 0;
}

.doc-item {
  display: flex; align-items: center; gap: .9rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .85rem .9rem;
  margin-bottom: .6rem;
}

.doc-icon {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; flex-shrink: 0;
}

.doc-icon.lab    { background: #e6f5fb; }
.doc-icon.imagen { background: #fff0e6; }
.doc-icon.receta { background: #e6f0ff; }

.doc-info { flex: 1; min-width: 0; }
.doc-info b     { font-size: .88rem; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.doc-info small { color: var(--text-muted); font-size: .75rem; }

.doc-actions { display: flex; gap: .4rem; }

.doc-btn {
  width: 32px; height: 32px; border-radius: 8px;
  border: 1.5px solid var(--border); background: none;
  font-size: .9rem; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background var(--transition);
}

.doc-btn:active { background: var(--accent-lt); }


/* ================================================================
   14. DOCTORES
================================================================ */
.doctor-card {
  background: var(--card); border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 1.1rem;
  margin-bottom: .9rem; position: relative;
}

.doctor-card.primary {
  background: linear-gradient(135deg, var(--dark2) 0%, #0f3a4d 100%);
}

.doctor-card.primary .dc-info h4,
.doctor-card.primary .dc-info p,
.doctor-card.primary .dc-info small { color: rgba(255,255,255,.9) !important; }

.dc-badge {
  display: inline-block; padding: .2rem .65rem;
  border-radius: 999px; font-size: .68rem; font-weight: 700;
  background: rgba(14,165,160,.2); color: var(--accent);
  margin-bottom: .7rem;
}

.dc-badge.spec { background: rgba(108,142,191,.2); color: #6c8ebf; }

.dc-avatar {
  width: 50px; height: 50px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #134e5e);
  color: #fff; display: flex; align-items: center;
  justify-content: center; font-size: 1.1rem; font-weight: 700;
  margin-bottom: .7rem;
}

.dc-info h4    { font-size: 1rem; font-weight: 700; }
.dc-info p     { font-size: .83rem; color: var(--text-muted); margin: .15rem 0; }
.dc-info small { font-size: .75rem; color: var(--text-muted); }

.dc-actions { display: flex; gap: .6rem; margin-top: .9rem; }

.dc-btn {
  flex: 1; padding: .55rem;
  border-radius: 9px; text-align: center;
  background: var(--accent); color: #fff;
  font-family: var(--font-body); font-size: .82rem;
  font-weight: 600; border: none; cursor: pointer;
  text-decoration: none; display: flex;
  align-items: center; justify-content: center;
  transition: background var(--transition);
}

.dc-btn:active { background: var(--accent-dk); }

.dc-btn.outline {
  background: transparent; color: var(--accent);
  border: 1.5px solid var(--accent);
}


/* ================================================================
   15. CITAS — CALENDARIO MINI
================================================================ */
.mini-calendar {
  background: var(--card); border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 1rem;
  margin-bottom: 1rem;
}

.mc-header {
  display: flex; justify-content: space-between; align-items: center;
  font-family: var(--font-display); font-size: .95rem; font-weight: 700;
  margin-bottom: .8rem;
}

.mc-nav {
  width: 30px; height: 30px; border-radius: 50%;
  border: 1.5px solid var(--border); background: none;
  font-size: 1rem; cursor: pointer; color: var(--text-muted);
}

.mc-days-header {
  display: grid; grid-template-columns: repeat(7, 1fr);
  text-align: center; margin-bottom: .4rem;
}

.mc-days-header span {
  font-size: .7rem; font-weight: 700;
  color: var(--text-muted); padding: .3rem 0;
}

.mc-grid {
  display: grid; grid-template-columns: repeat(7, 1fr);
  gap: .15rem;
}

.mc-day {
  aspect-ratio: 1; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .82rem; cursor: pointer;
  transition: background var(--transition), color var(--transition);
}

.mc-day:hover { background: var(--accent-lt); }
.mc-day.today { background: var(--accent); color: #fff; font-weight: 700; }
.mc-day.has-appt { position: relative; font-weight: 600; }

/* Punto indicador de cita debajo del número */
.mc-day.has-appt::after {
  content: ''; position: absolute; bottom: 2px;
  width: 4px; height: 4px; border-radius: 50%;
  background: var(--accent);
}

.mc-day.has-appt.today::after { background: #fff; }
.mc-day.selected { background: var(--dark); color: #fff; }
.mc-day.empty    { cursor: default; }

/* Filas de citas */
.appt-item {
  display: flex; align-items: center; gap: .8rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .8rem .9rem;
  margin-bottom: .5rem;
  border-left: 3px solid var(--border);
}

.appt-item.upcoming { border-color: var(--ok); }
.appt-item.past     { border-color: var(--text-muted); opacity: .8; }
.appt-item.study    { border-color: var(--info); }

.ai-time {
  font-size: .75rem; font-weight: 700;
  color: var(--text-muted); min-width: 46px;
  text-align: center; line-height: 1.3;
}

.ai-info { flex: 1; }
.ai-info b { font-size: .88rem; display: block; }
.ai-info p { font-size: .78rem; color: var(--text-muted); margin-top: .1rem; }

.ai-status {
  font-size: .7rem; font-weight: 700; padding: .2rem .6rem;
  border-radius: 999px; white-space: nowrap;
}

.ai-status.ok      { background: #d1f5e3; color: #1a7a46; }
.ai-status.warn    { background: #fef3d7; color: #8a5e0f; }
.ai-status.neutral { background: var(--bg); color: var(--text-muted); }
.ai-status.info    { background: #deeaf5; color: #2b5f8a; }
.ai-status.danger  { background: #fde8e8; color: #8f2020; }


/* ================================================================
   16. MEDICAMENTOS
================================================================ */
.med-card {
  display: flex; align-items: flex-start; gap: .9rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .9rem;
  margin-bottom: .6rem; position: relative;
}

.med-card.inactive { opacity: .6; }

.med-icon {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; flex-shrink: 0;
}

.med-main { flex: 1; }

.med-name  { font-size: .92rem; font-weight: 700; }
.med-dose  { font-weight: 400; color: var(--text-muted); font-size: .82rem; }
.med-doctor { font-size: .75rem; color: var(--text-muted); margin: .2rem 0 .5rem; }

.med-schedule { display: flex; flex-wrap: wrap; gap: .3rem; }

/* Píldora de horario — indica si ya fue tomada (taken) */
.ms-pill {
  padding: .2rem .6rem; border-radius: 999px;
  font-size: .72rem; font-weight: 700;
  background: var(--bg); color: var(--text-muted);
  border: 1.5px solid var(--border);
}

.ms-pill.taken {
  background: #d1f5e3; color: #1a7a46;
  border-color: #9de8c1;
}

/* Punto verde de estado activo */
.med-status.active-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--ok); flex-shrink: 0; margin-top: .3rem;
}


/* ================================================================
   17. ANÁLISIS / ESTUDIOS
================================================================ */
.study-item {
  display: flex; align-items: flex-start; gap: .9rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .9rem;
  margin-bottom: .6rem;
  border-left: 3px solid var(--accent);
}

.study-item.urgent { border-color: var(--danger); }
.study-item.done   { border-color: var(--ok); opacity: .75; }

.si-date-badge {
  min-width: 44px; text-align: center;
  background: var(--accent-lt); border-radius: 9px;
  padding: .4rem .3rem; flex-shrink: 0;
}

.si-date-badge.done { background: #d1f5e3; }

.si-day   { display: block; font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: var(--accent); line-height: 1; }
.si-month { display: block; font-size: .65rem; font-weight: 700; color: var(--text-muted); }

.si-date-badge.done .si-day { color: #1a7a46; }

.si-info { flex: 1; }
.si-info b { font-size: .88rem; display: block; margin-bottom: .2rem; }
.si-info p { font-size: .78rem; color: var(--text-muted); margin-bottom: .4rem; }

.si-tags { display: flex; flex-wrap: wrap; gap: .3rem; }

.si-tag {
  padding: .15rem .55rem; border-radius: 999px;
  font-size: .68rem; font-weight: 700;
  background: var(--bg); color: var(--text-muted);
  border: 1px solid var(--border);
}


/* ================================================================
   18. VACUNAS
================================================================ */
.vaccine-item {
  display: flex; align-items: center; gap: .9rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .9rem;
  margin-bottom: .6rem;
}

.vac-icon { font-size: 1.4rem; flex-shrink: 0; }

.vac-info { flex: 1; }
.vac-info b { font-size: .88rem; display: block; }
.vac-info p { font-size: .75rem; color: var(--text-muted); margin-top: .1rem; }

.vac-badge {
  padding: .2rem .65rem; border-radius: 999px;
  font-size: .7rem; font-weight: 700; white-space: nowrap;
}

.vac-badge.ok      { background: #d1f5e3; color: #1a7a46; }
.vac-badge.warn    { background: #fef3d7; color: #8a5e0f; }
.vac-badge.neutral { background: var(--bg); color: var(--text-muted); }


/* ================================================================
   19. NOTIFICACIONES
================================================================ */
.notif-item {
  display: flex; align-items: flex-start; gap: .8rem;
  background: var(--card); border-radius: var(--radius-sm);
  box-shadow: var(--shadow); padding: .9rem;
  margin-bottom: .6rem; cursor: pointer;
  transition: opacity var(--transition);
  border-left: 3px solid transparent;
}

/* No leída */
.notif-item.unread { border-left-color: var(--accent); }

.ni-icon {
  width: 36px; height: 36px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0;
}

.ni-icon.cita  { background: #e6f5fb; }
.ni-icon.med   { background: #fff0e6; }
.ni-icon.lab   { background: #e6f7f0; }
.ni-icon.vac   { background: #fef3d7; }
.ni-icon.token { background: var(--accent-lt); }

.ni-body { flex: 1; }
.ni-body b     { font-size: .88rem; display: block; margin-bottom: .2rem; }
.ni-body p     { font-size: .78rem; color: var(--text-muted); line-height: 1.45; }
.ni-body small { font-size: .72rem; color: var(--text-muted); margin-top: .3rem; display: block; }


/* ================================================================
   20. TOKEN DE ACCESO MÉDICO
================================================================ */
.token-status-card {
  background: linear-gradient(135deg, var(--dark2), #0f3a4d);
  border-radius: var(--radius); padding: 1.4rem;
  text-align: center; box-shadow: var(--shadow-lg);
}

.tsc-icon { font-size: 2.5rem; margin-bottom: .7rem; }

/* Código grande del token */
.token-code {
  font-family: var(--font-display);
  font-size: 1.6rem; font-weight: 800;
  color: var(--accent); letter-spacing: .15em;
  margin: .5rem 0;
  text-shadow: 0 0 20px rgba(14,165,160,.5);
}

.tsc-desc { color: rgba(255,255,255,.7); font-size: .88rem; }
.tsc-sub  { color: rgba(255,255,255,.45); font-size: .82rem; margin-top: .3rem; }

.token-time {
  color: #fff; font-size: .85rem; font-weight: 600;
  margin: .3rem 0 .8rem;
}

/* Barra de progreso de vida del token */
.token-progress {
  width: 100%; height: 4px; background: rgba(255,255,255,.15);
  border-radius: 999px; overflow: hidden; margin-bottom: .8rem;
}

.tp-bar {
  height: 100%; background: var(--accent);
  border-radius: 999px;
  transition: width 1s linear;
}

.token-doctor { font-size: .8rem; color: rgba(255,255,255,.55); }
.token-doctor b { color: rgba(255,255,255,.85); }

/* Checkboxes de permisos del token */
.token-perms { display: flex; flex-direction: column; gap: .5rem; }

.perm-row {
  display: flex; align-items: center; gap: .7rem;
  font-size: .88rem; cursor: pointer; padding: .3rem 0;
}

.perm-row input[type="checkbox"] {
  width: 18px; height: 18px;
  accent-color: var(--accent); cursor: pointer;
}

.old-token-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: .6rem 0; border-bottom: 1px solid var(--border);
  font-size: .83rem;
}

.old-token-row:last-child { border-bottom: none; }
.old-token-row b     { display: block; font-family: 'Courier New', monospace; letter-spacing: .06em; }
.old-token-row small { color: var(--text-muted); font-size: .75rem; }


/* ================================================================
   21. BOTTOM SHEETS
================================================================ */

/* Overlay oscuro */
.sheet-overlay {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(13,27,42,.55);
  opacity: 0; pointer-events: none;
  transition: opacity .3s;
}

.sheet-overlay.open { opacity: 1; pointer-events: all; }

/* Panel deslizable */
.bottom-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  z-index: 101;
  background: var(--card); border-radius: 20px 20px 0 0;
  padding: .8rem 1.3rem 2rem;
  max-height: 85vh; overflow-y: auto;
  box-shadow: 0 -8px 40px rgba(13,27,42,.25);
  transform: translateY(100%);    /* Oculto abajo por defecto */
  transition: transform .35s cubic-bezier(.4,0,.2,1);
}

.bottom-sheet.tall { max-height: 92vh; }
.bottom-sheet.open { transform: translateY(0); }

/* Indicador de arrastre */
.bs-handle {
  width: 40px; height: 4px; border-radius: 999px;
  background: var(--border); margin: 0 auto .9rem;
}

.bs-title {
  font-family: var(--font-display);
  font-size: 1.05rem; font-weight: 700;
  margin-bottom: 1.1rem;
}

/* Opciones de subida de archivos */
.upload-options {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: .7rem; margin-bottom: 1.2rem;
}

.uo-item {
  background: var(--bg); border-radius: var(--radius-sm);
  padding: 1.1rem .5rem; text-align: center;
  cursor: pointer; font-size: 1.6rem;
  display: flex; flex-direction: column;
  align-items: center; gap: .3rem;
  border: 1.5px solid var(--border);
  transition: background var(--transition);
}

.uo-item:active { background: var(--accent-lt); border-color: var(--accent); }
.uo-item small  { font-size: .75rem; font-weight: 600; color: var(--text-muted); }

/* Vista previa de documento */
.doc-preview-placeholder {
  background: var(--bg); border-radius: var(--radius-sm);
  border: 2px dashed var(--border);
  padding: 3rem 1rem; text-align: center;
  margin: 1rem 0; color: var(--text-muted);
  font-size: 2.5rem;
}

.doc-preview-placeholder p     { font-size: .9rem; margin: .5rem 0 .2rem; color: var(--text); }
.doc-preview-placeholder small { font-size: .78rem; }


/* ================================================================
   22. FORMULARIOS
================================================================ */
.field-group { margin-bottom: 1rem; }

.field-group label {
  display: block; font-size: .75rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .05em;
  color: var(--text-muted); margin-bottom: .4rem;
}

.app-input,
.app-select {
  width: 100%; padding: .75rem 1rem;
  border: 1.5px solid var(--border); border-radius: var(--radius-sm);
  font-family: var(--font-body); font-size: .95rem; color: var(--text);
  background: #fff; outline: none;
  transition: border-color var(--transition);
  /* Tamaño de fuente mínimo 16px para evitar zoom en iOS al enfocar */
  font-size: 16px;
}

.app-input:focus,
.app-select:focus { border-color: var(--accent); }


/* ================================================================
   23. ANIMACIONES ADICIONALES
================================================================ */
/* Pulso para el token activo */
@keyframes tokenPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(14,165,160,.4); }
  50%       { box-shadow: 0 0 0 8px rgba(14,165,160,.0); }
}

.token-code { animation: tokenPulse 2.5s infinite; }


/* ================================================================
   24. RESPONSIVE / SAFE AREAS
   En pantallas más anchas (tablet, desktop) la app se centra
   como si fuera un teléfono, manteniendo el aspecto móvil.
================================================================ */
@media (min-width: 500px) {
  /* Centrar como un "frame de teléfono" en pantallas grandes */
  #app-shell,
  #screen-login,
  .sheet-overlay,
  .bottom-sheet {
    max-width: 430px;
    left: 50%;
    transform: translateX(-50%);
  }

  /* Los sheets abiertos no deben usar translateX por el .open transform */
  .bottom-sheet.open {
    transform: translateX(-50%) translateY(0);
  }

  #splash { max-width: 100%; left: 0; transform: none; }
}

/* Soporte para notch / home bar de iPhone */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
  .bottom-nav {
    padding-bottom: env(safe-area-inset-bottom);
    height: calc(var(--nav-h) + env(safe-area-inset-bottom));
  }
}
