{
  "name": "medichain",
  "version": "1.0.0",
  "description": "MediChain — App del Paciente",
  "main": "main.js",
  "author": "Tu Nombre",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "build:win":   "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },

  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  },

  "build": {
    "appId":       "com.medichain.paciente",
    "productName": "MediChain",

    "directories": {
      "output": "dist"
    },

    "files": [
      "index.html",
      "style.css",
      "script.js",
      "main.js",
      "*.png",
      "*.ico",
      "*.icns"
    ],

    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },

    "nsis": {
      "oneClick":         false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediChain"
    },

    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.healthcare-fitness"
    },

    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Health"
    }
  }
}